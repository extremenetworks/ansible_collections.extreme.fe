##start_node ${UUID_VOSS_DT[15]} &
##start_node ${UUID_VOSS_DT[16]} &
##start_node ${UUID_VOSS_DT[17]}  Doesn't  run&
#
# Link the PC's through the DT's
#

# 1: TPC-1:1 to DT-1:4
connect_nodes ${UUID_TPC[1]} 1 0 "eth1" ${UUID_VOSS_DT[1]} 4 0 "1/4"
# 1: TPC-1:2 to DT-4:8
connect_nodes ${UUID_TPC[1]} 2 0 "eth2" ${UUID_VOSS_DT[4]} 8 0 "1/8"


# 2: TPC-2:1 to DT-2:4
connect_nodes ${UUID_TPC[2]} 1 0 "eth1" ${UUID_VOSS_DT[2]} 4 0 "1/4"
# 2: TPC-2:2 to DT-5:8
connect_nodes ${UUID_TPC[2]} 2 0 "eth2" ${UUID_VOSS_DT[5]} 8 0 "1/8"


# 3: Link DT-1:7 to DT-2:7 ( connect DT1 and DT2)
connect_nodes ${UUID_VOSS_DT[1]} 7 0 "1/7" ${UUID_VOSS_DT[2]} 7 0 "1/7"

# Create a LAG on ports 10 and 11 for DT4 and DT5
# 4: Link DT-4:10 to DT-5:10 ( connect DT4 and DT5) (LAG)
connect_nodes ${UUID_VOSS_DT[4]} 10 0 "1/10" ${UUID_VOSS_DT[5]} 10 0 "1/10"
# 4: Link DT-2:12 to DT-4:12 ( connect DT2 and DT4) (LAG)
connect_nodes ${UUID_VOSS_DT[4]} 11 0 "1/11" ${UUID_VOSS_DT[5]} 11 0 "1/11"


# Cross connect DT's on ports 12
# 5: Link DT-1:12 to DT-5:12 ( connect DT1 and DT5)
connect_nodes ${UUID_VOSS_DT[1]} 12 0 "1/12" ${UUID_VOSS_DT[5]} 12 0 "1/12"
# 5: Link DT-2:12 to DT-4:12 ( connect DT2 and DT4)
connect_nodes ${UUID_VOSS_DT[2]} 12 0 "1/12" ${UUID_VOSS_DT[4]} 12 0 "1/12"

# Connect the Dt1 and Dt4, for vIST connection and to test MLAG, use ports 15
connect_nodes ${UUID_VOSS_DT[1]} 15 0 "1/15" ${UUID_VOSS_DT[4]} 15 0 "1/15"

# Connect the Dt2 and Dt5, for vIST connection and to test MLAG, use ports 15
connect_nodes ${UUID_VOSS_DT[2]} 15 0 "1/15" ${UUID_VOSS_DT[5]} 15 0 "1/15"

wait
echo "GNS3 configured and running"

















