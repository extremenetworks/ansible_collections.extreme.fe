#/bin/bash

# Usage:
# pc_ping_cmd <IP of remote PC> <#Packets to send> <timeout in sec>
#

HOST_IP=$1
DEST_IP=$2
P=$2
T=$3

API="${HOST_IP}:8000"

cmd="ping -c 3 ${DEST_IP} | grep '3 packets received' | wc -l"

body=$(jq -n --arg cmd "$cmd" --argjson timeout 5 \
  '{commands:[$cmd], timeout_sec:$timeout}')

R=$(
  curl -s -X POST "http://$API/run" \
    -H 'Content-Type: application/json' \
    -d "$body" \
  | jq -r '.results[0].stdout | rtrimstr("\n")'
)



#R=`curl -s -X POST 'http://192.168.5.50:8000/run' -H 'Content-Type: application/json' -d '{"commands":["ping -c 3 192.168.5.1|grep \"3 packets received\"|wc -l"],"timeout_sec":5}' | jq -r '.results[0].stdout | rtrimstr("\n")'`

if [ "$R" = "1" ] ; then
  echo "Reachable"
else
  echo "Unreachable R=$R"
fi
