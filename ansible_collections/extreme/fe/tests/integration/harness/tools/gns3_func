# Create a SubNetRouter node in the project
#
create_subNetRouter_node () {
    XPOS=$1
    YPOS=$2
    LABEL_XPOS=$3
    LABEL_YPOS=$4

    #
    # First need to see if the right template is present for the SubNetRouter
    #
    R=`curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates" | grep "SubNetRouter" | wc -l`
    if [ "$R" = "0" ] ; then

        # Template is not available, create it
        echo "  SubNetRouter template not installed, adding new SubNetRouter template"
        R=`curl --fail --silent --show-error --location -X POST http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates \
            -H "Content-Type: application/json" \
            -d '{ \
            "name": "SubNetRouter", \
            "template_type": "docker", \
            "compute_id": "local", \
            "image": "ubserver:latest", \
            "adapters": 2, \
            "console_type": "telnet" \
            }'`
    fi

    # Retrieve the templace ID
    snt_t_id=0
    snt_t_id=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates" | jq -r '.[] | select(.name=="SubNetRouter") | .template_id')
    echo "  Using SubNetRouter template ID: $snt_t_id"

    # Determine if we have a route to the test network
    # Uses SUBNET_ROUTER_GATEWAY and SUBNET_ROUTER_NETWORK from gns3.cfg
    if [ -n "$SUBNET_ROUTER_GATEWAY" ] && [ -n "$SUBNET_ROUTER_NETWORK" ]; then
        R=`ip route | grep "$SUBNET_ROUTER_GATEWAY" | wc -l`
        if [ "$R" = "0" ] ; then
            # Need to install the route
            echo "Installing route to $SUBNET_ROUTER_NETWORK through gateway $SUBNET_ROUTER_GATEWAY"
            ip route add $SUBNET_ROUTER_NETWORK via $SUBNET_ROUTER_GATEWAY
        fi
    fi

    if [ "$snt_t_id" = "0" ] ; then
        echo "  *** ERROR *** : SubNetRouter template ID could not be found"
        exit 1
    fi

    # Create the ubserverR router
    template_ID="$snt_t_id" 
    RESULT=$(curl  --fail  --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/templates/$template_ID" \
        --data "{\"name\": \"Subnet Router\", \"compute_id\": \"${COMPUTE_ID}\", \"x\": $XPOS, \"y\": $YPOS}")
    UUID_SROUTER=$(jq --raw-output ".node_id" <<< "${RESULT}")
    curl --fail --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${UUID_SROUTER}" \
        --data "{\"name\": \"Subnet Router\"}" > /dev/null
    curl --fail --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${UUID_SROUTER}" \
        --data "{\"symbol\": \":/symbols/classic/router.svg\",\
        \"label\": {\"rotation\": 0, \"style\": \"null\", \"text\": \"LAN\", \"x\": $LABEL_XPOS, \"y\": $LABEL_YPOS}}" > /dev/null

    # Link the eth0 of the Subnet Router to the UNET cloud adapter
    connect_nodes "${UUID_UNET}" "${GNS3_LAN_ADAPTER}" "${GNS3_LAN_PORT_NR}" "${GNS3_LAN_PORT}" "${UUID_SROUTER}" 0 0 "eth0"
    echo "  SubNetRouter UUID:$UUID_SROUTER"
}

