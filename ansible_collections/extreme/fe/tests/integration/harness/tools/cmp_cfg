#!/bin/bash

#
# Script that compares the current runing config with the start_config
#

RESET=$1

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
ANSIBLE_ROOT=${ANSIBLE:-}
if [ -z "$ANSIBLE_ROOT" ]; then
    ANSIBLE_ROOT=$(cd -- "$SCRIPT_DIR/../.." && pwd -P)
fi

FE_EXEC_CLI_CMD="$ANSIBLE_ROOT/tests/integration/harness/tools/fe_exec_cli_cmds.exp"
# Filename that contains the FE CLI commands
CLI_COMMAND_FILE="tests/integration/harness/tools/fe_save_config-1.cli"
RESET_SCRIPT="$ANSIBLE_ROOT/tests/integration/harness/tools/reset_cfg"
SELF_SCRIPT="$SCRIPT_DIR/cmp_cfg"
SCP_EXPECT="$ANSIBLE_ROOT/tests/integration/harness/tools/scp_expect.sh"
CFG_DIR="$ANSIBLE_ROOT/tests/integration/harness/cfg"
GNS3_CFG="$CFG_DIR/gns3.cfg"

if [ ! -f "$GNS3_CFG" ]; then
    echo "Required configuration not found: $GNS3_CFG" >&2
    exit 1
fi

SUBNET_ROUTER_NETWORK=$(grep -E '^SUBNET_ROUTER_NETWORK=' "$GNS3_CFG" | tail -n 1 | cut -d '=' -f2)
if [ -z "$SUBNET_ROUTER_NETWORK" ]; then
    echo "Unable to determine SUBNET_ROUTER_NETWORK from $GNS3_CFG" >&2
    exit 1
fi

if [ ! -x "$FE_EXEC_CLI_CMD" ]; then
    echo "Required script not executable: $FE_EXEC_CLI_CMD" >&2
    exit 1
fi

if [[ "$CLI_COMMAND_FILE" != /* ]]; then
    CLI_COMMAND_FILE="$ANSIBLE_ROOT/$CLI_COMMAND_FILE"
fi

if [ ! -f "$CLI_COMMAND_FILE" ]; then
    echo "Command file not found: $CLI_COMMAND_FILE" >&2
    exit 1
fi

if [ "$RESET" = "fix" ] && [ ! -x "$RESET_SCRIPT" ]; then
    echo "Reset helper not executable: $RESET_SCRIPT" >&2
    exit 1
fi

# Number of devices
COUNT="0 1 3 4"
#COUNT="0"

# Last digit of IP of each device
IPBASE="192.168.$SUBNET_ROUTER_NETWORK"
IP=("101" "102" "103" "104" "105")

# Login credentials
USER="rwa"
PASS="rwa"

# Function to be executed when Ctrl-C (SIGINT) is caught
cleanup_on_ctrl_c() {
    echo -e "\nCtrl-C detected! Exitting..."
    exit 1 # Exit with a non-zero status to indicate abnormal termination
}

# Set the trap: When SIGINT is received, call the cleanup_on_ctrl_c function
trap cleanup_on_ctrl_c SIGINT

rm -rf /tmp/cmp_cfg/*
mkdir -p /tmp/cmp_cfg

# Go through all devices
for i in $COUNT; do
    #echo "Saving config on switch: DT-$((i + 1)) : ${IPBASE}.${IP[$i]}"
    "$FE_EXEC_CLI_CMD" "$CLI_COMMAND_FILE" "${IPBASE}.${IP[i]}" "$USER" "$PASS" > \
        /tmp/cmp_cfg/log-DT-$((i + 1)).txt &
done

wait

# Now scp files from DT's to local host
rm -rf /tmp/cmp_cfg.tmp
for i in $COUNT; do
    #echo "Transferring files from switch: DT-$((i + 1)) : ${IPBASE}.${IP[$i]}"
    #scp_expect.sh $USER ${IPBASE}.${IP[i]} /intflash/start_test.cfg /tmp/cmp_cfg/start_test-DT-$((i +1)).cfg $PASS
    $SCP_EXPECT ${USER}@${IPBASE}.${IP[i]}:/intflash/config-1.cfg /tmp/cmp_cfg/running-DT-$((i +1)).cfg $PASS &
done

wait

echo "Comparing configuration files ...."

R=PASS

for i in $COUNT; do
    if ! [ -f $CFG_DIR/start_test-DT-$((i +1)).cfg ] || ! [ -f /tmp/cmp_cfg/running-DT-$((i +1)).cfg ] ; then
    	echo "FAIL: Missing configuration file(s) for DT-$((i + 1))"
	    exit 1
    fi

    # Remove comments, empty lines and "exit" commands before comparing
    cat $CFG_DIR/start_test-DT-$((i +1)).cfg | grep -v "^#" | grep -v "^$" | grep -v "^exit" > /tmp/cmp_cfg/d_start_test-DT-$((i +1)).cfg

    # Remove comments, empty lines, "exit" commands before comparing
    # Remove also fixfish related lines, for 9.4.0.0 branch, probably a bug in 9.4.0.0
    # Remove also auto-sense configuration that is set to the default vlalue, like "auto-sense wait-interval 35"
    cat /tmp/cmp_cfg/running-DT-$((i +1)).cfg | grep -v "^#" | grep -v "^$" | grep -v "^exit" | grep -v "^no ip ipfix port " | grep -v "^auto-sense wait-interval 35" > /tmp/cmp_cfg/d_running-DT-$((i +1)).cfg
    diff /tmp/cmp_cfg/d_start_test-DT-$((i +1)).cfg /tmp/cmp_cfg/d_running-DT-$((i +1)).cfg > /tmp/cmp_cfg/diff-DT-$((i +1)).txt
    if [ $? -eq 0 ]; then
        echo "No differences found on switch DT-$((i + 1))" >>/tmp/cmp_cfg/results.txt
    else
        echo "Differences found on switch DT-$((i + 1))! See /tmp/cmp_cfg/diff-DT-$((i +1)).txt for details." >>/tmp/cmp_cfg/results.txt
        echo "${IPBASE}.${IP[i]} fails"

        if [ "$RESET" = "fix" ] ; then        
            # Reset this device
            (
                cd "$ANSIBLE_ROOT" && "$RESET_SCRIPT" "${IPBASE}.${IP[i]}"
            ) &
        else
            R="FAIL"
        fi
    fi
done

wait

if [ "$RESET" = "fix" ] ; then
    # check one more time, now without the "fix" option
    if "$SELF_SCRIPT" ; then
        R="PASS"
    else
        R="FAIL"
    fi
fi

echo "$R"
if [ "$R" = "FAIL" ] ; then
    exit 1
fi

exit 0
