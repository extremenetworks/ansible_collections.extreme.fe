#
# Function to issue a start to the gns3 for a given node
#
start_node () {
    if [ "$UUID_PROJ}" = "" ] ; then
        echo "ERROR: No project UUID found, cannot start node"
        return 1;
    fi
    NODE_ID=$1
    curl --fail --silent --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${NODE_ID}/start" --data "{}" > /dev/null
    return 0
}

#
# Function that starts all nodes in a project
#
start_all_nodes () {
    if [ "$UUID_PROJ}" = "" ] ; then
        echo "ERROR: No project UUID found, cannot start node"
        return 1;
    fi

    # Get all the nodes
    RESULT=$(curl --fail --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes" | jq -r '.[].node_id') 
    if [ -n "$GNS3_DEBUG" ]; then
        echo "RESULT:$RESULT"
    fi

    # Re-iterate through all nodes and if they have not been started, start them
    for NODE_ID in $RESULT; do
        # Get the status of the node
        NODE_STATUS=$(curl  --fail --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${NODE_ID}" | jq -r '.status')
        #echo "NODE_ID:$NODE_ID STATUS:$NODE_STATUS"
        if [ "$NODE_STATUS" != "started" ] ; then
            echo "Starting node UUID:$NODE_ID (status:$NODE_STATUS)"
            start_node $NODE_ID
        fi
    done
}

#############################################################
## Connect 2 nodes together
#############################################################
connect_nodes () {
    NODE_ID_1=$1
    AD_1=$2
    PORT_1=$3
    TEXT1=$4
    NODE_ID_2=$5
    AD_2=$6
    PORT_2=$7
    TEXT2=$8

    curl --fail --silent --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/links" --data "{\
        \"nodes\": [\
            {\"node_id\": \"${NODE_ID_1}\", \"adapter_number\": ${AD_1}, \"port_number\": ${PORT_1}, \"label\": {\"text\": \"${TEXT1}\"}}, \
            {\"node_id\": \"${NODE_ID_2}\", \"adapter_number\": ${AD_2}, \"port_number\": ${PORT_2}, \"label\": {\"text\": \"${TEXT2}\"}}\
            ]}" >/dev/null
}

#############################################################
## Start a DT
## ARGS: <NAME> <DEVICE_OS> <DEVICE#> <DEVICE_MAC> <NUM_PORTS> <DISK_IMG> <XPOS> <YPOS> <SW_NR> <SW_PORT> 
##
#############################################################
create_dt () {

    NAME=$1
    DEVICE_OS=$2
    DEVICE_NUM=$3
    DEVICE_MAC=$4
    NUM_PORTS=$5
    DISK_IMG=$6
    XPOS=$7
    YPOS=$8
    SW_NR=$9
    SW_PORT=${10}

    COMPUTE_ID="local"

    NODE_NAME="${DEVICE_OS}-dt${DEVICE_NUM}-${NAME}"

    # 5320 does not have an oob port!
    DEV_FAM=`echo ${NAME} | sed 's/-/ /g' | awk '{ print $1 }'`

    FIRST_PORT_NAME="Mgmt"
    ADAPTER="0"
    MGMT_PORT="Mgmt"
    if [ "${DEV_FAM}" = "5320" ] ; then
        FIRST_PORT_NAME="N/A"   
        ADAPTER="1"
        MGMT_PORT="1/1"
    fi

    # Determine with switch port to connect the oob port to
    if [ "${DEVICE_OS}" = "voss" ] ; then
      # VOSS devices connect to Switch ports 3,4,5,6,7
      OS_NUM=2
    else 
      # EXOS devices connect to port 1 and 2
      OS_NUM=0 
    fi
    
    echo "Creating ${NODE_NAME}: Image:$DISK_IMG MAC:$DEVICE_MAC"
    # TYPE:5420F-16W-32P-4XE"

    # Get the project UUID
    UUID_PROJ=$(get_project_UUID)
    
    # Create a new instance
    
    RESULT=$(curl --fail --silent --show-error --location --request POST \
      "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes" \
      --data "{ \
        \"name\": \"${NODE_NAME}\", \
        \"compute_id\": \"${COMPUTE_ID}\", \
        \"x\": ${XPOS}, \
        \"y\": ${YPOS}, \
        \"node_type\": \"qemu\", \
        \"symbol\": \":/symbols/affinity/circle/gray/switch_multilayer.svg\", \
        \"first_port_name\": \"${FIRST_PORT_NAME}\", \
        \"port_name_format\": \"1/{port1}\", \
        \"properties\": { \
            \"platform\": \"x86_64\", \
            \"hda_disk_image\": \"${DISK_IMG}\", \
            \"ram\": 2048, \
            \"cpus\": 2, \
            \"on_close\": \"power_off\", \
            \"adapters\": ${NUM_PORTS}, \
            \"mac_address\": \"${DEVICE_MAC}\", \
            \"boot_priority\": \"c\", \
            \"process_priority\": \"normal\", \
            \"adapter_type\": \"e1000\", \
            \"hda_disk_interface\": \"ide\", \
            \"options\": \"-enable-kvm\" \
      } \
    }")

    UUID_NODE=$(jq --raw-output ".node_id" <<< "${RESULT}")

    # Need to ADD check for EXOS -- ** --
    UUID_VOSS_DT[$DEVICE_NUM]=${UUID_NODE}
    echo "  Created DT: ${NODE_NAME} UUID:${UUID_NODE}"

    # Connect the DT to the mgmt network
    connect_nodes "${UUID_NODE}" "$ADAPTER" "0" "$MGMT_PORT" "${UUID_SW[$SW_NR]}" "0" "${SW_PORT}" "${SW_PORT}"

}

#############################################################
# Function to create a Traffic PC
#############################################################
# Create the Traffic PC node: 
# create_tpc "TPC-1" $pct_id 1   45 -330 "02:42:d0:aa:00:50" &
#
create_tpc () {

    NAME=$1
    TPL=$2
    PC_NR=$3
    XPOS=$4
    YPOS=$5
    MAC=$6

    # See if we have a TPC template
    if [ "$TEMPLATE_TPC" == "" ] ; then
       # We may need to create a new template for the TPC
       echo "Check if traffic template exists"
       
        R=`curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates" | grep "TrafficPC" | wc -l`
        if [ "$R" = "0" ] ; then

            # Template is not available, create it
            echo "  TrafficPC template not installed, adding new TrafficPC template"
            R=`curl --fail --silent --show-error --location -X POST http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates \
                -H "Content-Type: application/json" \
                -d '{ \
                "name": "TrafficPC", \
                "template_type": "docker", \
                "compute_id": "local", \
                "image": "pc:latest", \
                "adapters": 6, \
                "console_type": "telnet" \
                }'`
        fi
	echo "Retrieve the traffic template"

        # Retrieve the Traffic PC templace ID
        TEMPLATE_TPC=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/templates" | jq -r '.[] | select(.name=="TrafficPC") | .template_id')
    fi
    echo "  Using TrafficPC template ID: $TEMPLATE_TPC"

    # Create the TPC now
    RESULT=$(curl --fail --silent --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/templates/$TEMPLATE_TPC" --data "{\"name\": \"$NAME\", \"compute_id\": \"${COMPUTE_ID}\", \"x\": $XPOS, \"y\": $YPOS}")
    UUID_TPC_L=$(jq --raw-output ".node_id" <<< "${RESULT}")
    echo "  TrafficPC $NAME: UUID:$UUID_TPC_L"
    curl --fail --silent --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${UUID_TPC_L}" --data "{\"name\": \"$NAME\"}" > /dev/null
    curl --fail --silent --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${UUID_TPC_L}" --data "{\"symbol\": \":/symbols/affinity/circle/gray/laptop.svg\"}" > /dev/null
    curl --fail --silent --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes/${UUID_TPC_L}" --data "{\"properties\": {\"adapters\": 6, \"mac_address\": \"$MAC\" }}" > /dev/null

    UUID_TPC[${PC_NR}]="${UUID_TPC_L}"
}

