#
# Check if the GNS3 server is alive
#
check_gns3_server () {
    EXIT_ON_ERROR=$1

    RESULT=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects" | grep "\[" | wc -l 2>/dev/null)
    if [ "$RESULT" = "0" ] ; then
        RESULT=$(ping $GNS3_SERVER_HOST -c 1 | grep " 1 received, " | wc -l)
        if [ "$RESULT" = "0" ] ; then
            echoErrGreen "ERROR: GNS3 SERVER: $GNS3_SERVER not reachable"
            if [ "$EXIT_ON_ERROR" = "exit_on_error" ] ; then
                exit 1
            fi
        else
            echoErrGreen "ERROR: GNS3 server $GNS3_SERVER_HOST is alive, however the GNS3 server application does not respond"
            if [ "$EXIT_ON_ERROR" = "exit_on_error" ] ; then
                exit 1
            fi
        fi
    fi

    # Success
    return 0
}

check_project_UUID () {
    # See if we already have one
    if ! [ "$UUID_PROJ" = "" ] ; then
        echo "$UUID_PROJ"
        return
    fi

    if [ "$GNS3_PROJECT_NAME" = "" ] ; then
        echoErrGreen "ERROR: No GNS3 project name" 
        echo ""
        return 
    fi

    check_gns3_server no_exit_on_error

    if [ "$?" = "0" ] ; then
        RESULT=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects")
        UUID_PROJ=$(jq --raw-output ".[] | select( .name == \"${GNS3_PROJECT_NAME}\" ).project_id" <<< "${RESULT}")
    fi

    echo "$UUID_PROJ"
}

#
# Function that returns the UUID for the project (UUID_PROJ)
#
get_project_UUID () {
    # See if we already have one
    if ! [ "$UUID_PROJ" = "" ] ; then
        echo "$UUID_PROJ"
        return
    fi

    if [ "$GNS3_PROJECT_NAME" = "" ] ; then
        echoErrGreen "ERROR: No GNS3 project name given to remove from GNS3 server" 
        echo ""
        return 
    fi

    check_gns3_server no_exit_on_error

    if [ "$?" = "0" ] ; then
        RESULT=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects")
        UUID_PROJ=$(jq --raw-output ".[] | select( .name == \"${GNS3_PROJECT_NAME}\" ).project_id" <<< "${RESULT}")
    fi

    if [ "$UUID_PROJ" = "" ] ; then
        echoErrGreen "ERROR: Project ${GNS3_PROJECT_NAME} on Server: ${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT} does not exist"
    fi
    echo "$UUID_PROJ"
}

#
# Return the UUID for the given switch
#
get_switch_UUID () {

    SW_NAME=$1    

    UUID_PROJ=$(get_project_UUID)

    RESULT=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/nodes")
    UUID_NODE=$(jq --raw-output ".[] | select( .name == \"$SW_NAME\" ).node_id" <<< "${RESULT}")

    if [ "$UUID_NODE" = "" ] ; then
        echoErrGreen "ERROR: Could not find UUID node for switch: $SW_NAME"
    fi

    echo "$UUID_NODE"
    return
} 

#
# Function that removes a GNS3 project from the server
#
remove_gns3_project () {

    if [ "$GNS3_PROJECT_NAME" = "" ] ; then
        echo "ERROR: No GNS3 project name given to remove from GNS3 server"
        return 1
    fi

    check_gns3_server no_exit_on_error
    if [ "$?" = "0" ] ; then
        RESULT=$(curl --fail --silent --show-error --location --request GET "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects")
        UUID_PROJ=$(jq --raw-output ".[] | select( .name == \"${GNS3_PROJECT_NAME}\" ).project_id" <<< "${RESULT}")
        if ! [ "${UUID_PROJ}" = "" ] ; then
           echo "Removing project: ${GNS3_PROJECT_NAME}"
           curl --fail --silent --show-error --location --request DELETE "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}" > /dev/null || true
           UUID_PROJ=""
           #echo "Removed project: ${GNS3_PROJECT_NAME}"
        fi
    fi
}

create_new_project () {

    scene_width=$1
    scene_height=$2
    drawing_grid_size=$3
    grid_size=$4
    show_grid=$5
    snap_to_grid=$6

    # Make sure an old project is removed first
    remove_gns3_project

    # Create the new project
    RESULT=$(curl --fail --silent --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects" --data "{\"name\": \"${GNS3_PROJECT_NAME}\"}")

    # Store the UUID for later use
    UUID_PROJ=$(jq --raw-output ".project_id" <<< "${RESULT}")

    # Set the projects params
    curl --fail --silent --show-error --location --request PUT "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}" --data "{\
        \"scene_width\": $scene_width, \
        \"scene_height\": $scene_height, \
        \"drawing_grid_size\": $drawing_grid_size, \
        \"grid_size\": $grid_size, \
        \"show_grid\": $show_grid, \
        \"snap_to_grid\": $snap_to_grid \
        }" > /dev/null

    curl --fail --silent --show-error --location --request POST "http://${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT}/v2/projects/${UUID_PROJ}/open" --data "{}" > /dev/null
    echo "GNS3 server:${GNS3_SERVER_HOST}:${GNS3_SERVER_PORT} -> New project: ${GNS3_PROJECT_NAME} UUID:${UUID_PROJ}"
}

